# Copy this file to .env and replace placeholder values.

# Server Configuration
PORT=3000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/CargoLink

# JWT Configuration
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=replace-me

# Admin Credentials
ADMIN_EMAIL=admin@cargolink.com
ADMIN_PASSWORD=replace-me

# Razorpay Payment Gateway (Test Mode)
RAZORPAY_KEY_ID=replace-me
RAZORPAY_KEY_SECRET=replace-me

# Google Maps API
GOOGLE_MAPS_API_KEY=replace-me

# Redis Cache
REDIS_URL=redis://127.0.0.1:6379
CACHE_ENABLED=true
CACHE_PREFIX=cargolink:dev
CACHE_VERSION=v1
CACHE_DEFAULT_TTL=45
CACHE_EXTERNAL_TTL=1800
