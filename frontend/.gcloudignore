# Cloud Build / gcloud deploy will NOT upload any of the following.

# Dependencies — not needed since GAE serves static assets from dist/
node_modules/

# Tests
__test__/
playwright-report/
test-results/

# Source files — only dist/ is needed at runtime
src/
index.html
vite.config.js
eslint.config.js
playwright.config.js

# Local env
.env
.env.*

# Logs
*.log

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Lock file intentionally included.
