# Force LF line endings for all YAML and shell files in this repo.
# This prevents Windows CRLF from corrupting Cloud Build inline bash scripts.

*.yaml      text eol=lf
*.yml       text eol=lf
*.sh        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.env*      text eol=lf
.gitignore  text eol=lf
.gcloudignore text eol=lf
